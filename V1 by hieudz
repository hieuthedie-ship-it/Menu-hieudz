-- Chức năng ESP Định vị người chơi (Vẽ khung vuông góc)
local function CreateESP(player)
    if player == LocalPlayer then return end
    local function apply()
        player.CharacterAdded:Connect(function(char)
            if not Options.ESP then return end
            task.wait(0.5)
            if char:FindFirstChild("Highlight") then return end
            local hl = Instance.new("Highlight", char)
            hl.FillColor = Color3.fromRGB(255, 255, 255)
            hl.OutlineColor = Color3.fromRGB(0, 0, 0)
            hl.FillTransparency = 0.5
        end)
        if player.Character and not player.Character:FindFirstChild("Highlight") and Options.ESP then
            local hl = Instance.new("Highlight", player.Character)
            hl.FillColor = Color3.fromRGB(255, 255, 255)
            hl.OutlineColor = Color3.fromRGB(0, 0, 0)
            hl.FillTransparency = 0.5
        end
    end
    apply()
end

AddToggle("ESP (Định vị Player)", function(state)
    Options.ESP = state
    if state then
        for _, p in ipairs(Players:GetPlayers()) do CreateESP(p) end
    else
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("Highlight") then p.Character.Highlight:Destroy() end
        end
    end
end)
Players.PlayerAdded:Connect(CreateESP)

