-- Chức năng Fly (Bay)
AddToggle("Fly (Bay tự do)", function(state)
    Options.Fly = state
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    if state then
        local bv = Instance.new("BodyVelocity", root)
        bv.Name = "HieuDz_Fly"
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Velocity = Vector3.new(0,0,0)
        
        task.spawn(function()
            while Options.Fly and root and bv.Parent do
                local camCFrame = workspace.CurrentCamera.CFrame
                local dir = Vector3.new(0,0,0)
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + camCFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - camCFrame.LookVector end
                bv.Velocity = dir * (Options.WalkSpeed * 2)
                task.wait()
            end
        end)
    else
        if root:FindFirstChild("HieuDz_Fly") then root.HieuDz_Fly:Destroy() end
    end
end)

-- Chức năng Float (Lơ lửng)
local floatPart = nil
AddToggle("Float (Lơ lửng trên không)", function(state)
    Options.Float = state
    if state then
        task.spawn(function()
            while Options.Float do
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if root then
                    if not floatPart or not floatPart.Parent then
                        floatPart = Instance.new("Part", char)
                        floatPart.Size = Vector3.new(4, 0.5, 4)
                        floatPart.Transparency = 0.7 -- Nhìn thấy tấm kính mờ màu trắng dưới chân
                        floatPart.Anchored = true
                    end
                    floatPart.CFrame = root.CFrame * CFrame.new(0, -3.25, 0)
                end
                task.wait()
            end
        end)
    else
        if floatPart then floatPart:Destroy() floatPart = nil end
    end
end)

