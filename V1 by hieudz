-- Tạo nút Bật / Tắt
local function AddToggle(name, callback)
    local Frame = Instance.new("Frame", ContentFrame)
    Frame.Size = UDim2.new(1, -5, 0, 28)
    Frame.BackgroundTransparency = 1

    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(0.6, 0, 1, 0)
    Label.Text = " " .. name
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.Font = Enum.Font.GothamSemibold
    Label.TextSize = 10
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.BackgroundTransparency = 1

    local Btn = Instance.new("TextButton", Frame)
    Btn.Size = UDim2.new(0, 60, 0, 20)
    Btn.Position = UDim2.new(1, -62, 0.5, -10)
    Btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Btn.Text = "TẮT"
    Btn.TextColor3 = Color3.fromRGB(0, 0, 0)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 9
    
    local btnCorner = Instance.new("UICorner", Btn)
    btnCorner.CornerRadius = UDim.new(0, 4)

    local state = false
    Btn.MouseButton1Click:Connect(function()
        state = not state
        if state then
            Btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            Btn.Text = "BẬT ✔"
            local s = Instance.new("UIStroke", Btn) s.Color = Color3.fromRGB(255, 255, 255) s.Thickness = 1
        else
            Btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Btn.TextColor3 = Color3.fromRGB(0, 0, 0)
            Btn.Text = "TẮT"
            if Btn:FindFirstChild("UIStroke") then Btn.UIStroke:Destroy() end
        end
        callback(state)
    end)
end

