-- 1. Moonwalk (Đi lùi)
CreateButton("1. MOONWALK: OFF", Color3.fromRGB(25, 25, 40), function(b)
    Moonwalk = not Moonwalk b.Text = Moonwalk and "1. MOONWALK: ON" or "1. MOONWALK: OFF"
    task.spawn(function()
        while Moonwalk do
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.MoveDirection.Magnitude > 0 then
                LocalPlayer.Character.HumanoidRootPart.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,0.4)
            end
            task.wait()
        end
    end)
end)

